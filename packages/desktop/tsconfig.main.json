{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": "../..",
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@pi-deck/core": ["../core/src/index.ts"],
      "@pi-deck/core/*": ["../core/src/*"]
    }
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/worker/**/*.ts",
    "../core/src/**/*.ts"
  ],
  "exclude": ["../core/src/**/*.test.ts"]
}
