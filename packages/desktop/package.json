{
  "name": "@pi-deck/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/main/index.mjs",
  "scripts": {
    "type-check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.main.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "dist": "bun run build && electron-builder --config electron-builder.yml"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.77.0",
    "@lydell/node-pty": "1.2.0-beta.12",
    "@pi-deck/core": "workspace:*",
    "@pi-deck/ui": "workspace:*",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "electron": "42.0.1",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "tree-kill": "1.2.2"
  }
}
