{
  "name": "@pi-deck/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/main/index.js",
  "scripts": {
    "type-check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.main.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test",
    "build:main": "bun build src/main/index.ts --target=node --format=cjs --external electron --external @earendil-works/pi-coding-agent --outfile=dist/main/index.js --sourcemap=inline",
    "build:preload": "bun build src/preload/index.ts --target=node --format=cjs --external electron --outfile=dist/preload/index.js --sourcemap=inline",
    "build:worker": "bun build ../core/src/worker/entry.ts --target=node --format=cjs --external @earendil-works/pi-coding-agent --outfile=dist/worker.js --sourcemap=inline",
    "build:backend": "bun run build:main && bun run build:preload && bun run build:worker",
    "build:renderer": "vite build",
    "build": "bun run build:renderer && bun run build:backend",
    "dev:main": "bun build src/main/index.ts --target=node --format=cjs --external electron --external @earendil-works/pi-coding-agent --outfile=dist/main/index.js --sourcemap=inline --watch",
    "dev:preload": "bun build src/preload/index.ts --target=node --format=cjs --external electron --outfile=dist/preload/index.js --sourcemap=inline --watch",
    "dev:worker": "bun build ../core/src/worker/entry.ts --target=node --format=cjs --external @earendil-works/pi-coding-agent --outfile=dist/worker.js --sourcemap=inline --watch",
    "dev": "bun run build:backend && concurrently -k -n vite,main,preload,worker,electron -c blue,yellow,cyan,magenta,green \"vite\" \"bun run dev:main\" \"bun run dev:preload\" \"bun run dev:worker\" \"electronmon --no-stdin .\"",
    "start": "electron .",
    "dist": "bun run build && electron-builder --config electron-builder.yml"
  },
  "dependencies": {
    "@pi-deck/core": "workspace:*",
    "@pi-deck/ui": "workspace:*",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^42.0.1",
    "electron-builder": "^25.0.0"
  }
}
