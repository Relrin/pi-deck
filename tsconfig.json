{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "bun"]
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/test/**/*.ts",
    "packages/*/test/**/*.tsx"
  ],
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/out",
    "packages/desktop/src/main/**",
    "packages/desktop/src/preload/**"
  ]
}
